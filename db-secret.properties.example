# 数据库连接信息示例文件
# 复制为 db-secret.properties 并填入真实值，该文件不会提交 Git
# 格式：<type>.<key>
# SSL 配置为可选项，配置证书路径后自动启用

mysql.host=192.168.1.100
mysql.port=3306
mysql.version=8.0
mysql.database=testdb
mysql.user=admin
mysql.password=your_password
# mysql.ssl.ca=certs/mysql/ca.pem
# mysql.ssl.cert=certs/mysql/cert.pem
# mysql.ssl.key=certs/mysql/key.pem

postgresql.host=192.168.1.100
postgresql.port=5432
postgresql.version=16
postgresql.database=testdb
postgresql.user=admin
postgresql.password=your_password
# postgresql.ssl.ca=certs/postgresql/ca.pem
# postgresql.ssl.cert=certs/postgresql/cert.pem
# postgresql.ssl.key=certs/postgresql/key.pem

oracle.host=192.168.1.100
oracle.port=1521
oracle.version=23ai
oracle.database=FREE
oracle.user=sys
oracle.password=your_password

h2.host=192.168.1.100
h2.port=9092
h2.version=2.x
h2.database=testdb
h2.user=sa
h2.password=
