#!/usr/bin/env bash
#
# check-boundary — 结构性测试：验证 skills/ 与代码模块的隔离性
#
# 用法: bin/check-boundary
# 退出码: 0=通过, 1=存在边界违规
#
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
ERRORS=0

echo "=== 边界隔离检查 ==="
echo ""

# --------------------------------------------------------------------------
# 检查 1: skills/*.md 中不得引用 db-*/src/ 下的文件路径或 Java 类
# --------------------------------------------------------------------------
echo "[检查 1] skills/ 中是否引用了代码模块源码路径..."

SKILL_TO_CODE=$(grep -rn --include="*.md" -E 'db-(common|mysql|postgresql|oracle|h2|clickhouse)/src/' "$REPO_ROOT/skills/" 2>/dev/null || true)
if [ -n "$SKILL_TO_CODE" ]; then
    echo "  ✗ 失败: skills/ 中引用了代码模块源码路径:"
    echo "$SKILL_TO_CODE" | sed 's/^/    /'
    echo "  ↳ 修复: 移除对 db-*/src/ 的引用，skills 不应假设代码模块的内部结构"
    ERRORS=$((ERRORS + 1))
else
    echo "  ✓ 通过"
fi

# --------------------------------------------------------------------------
# 检查 2: Java 源码中不得引用 skills/ 目录
# --------------------------------------------------------------------------
echo "[检查 2] Java 代码中是否引用了 skills/ 目录..."

CODE_TO_SKILL=$(grep -rn --include="*.java" -E 'skills/' "$REPO_ROOT"/db-*/src/ 2>/dev/null || true)
if [ -n "$CODE_TO_SKILL" ]; then
    echo "  ✗ 失败: Java 代码中引用了 skills/ 目录:"
    echo "$CODE_TO_SKILL" | sed 's/^/    /'
    echo "  ↳ 修复: 代码模块不应依赖 skills/ 中的任何内容"
    ERRORS=$((ERRORS + 1))
else
    echo "  ✓ 通过"
fi

# --------------------------------------------------------------------------
# 检查 3: resources 配置文件中不得引用 skills/
# --------------------------------------------------------------------------
echo "[检查 3] resources 中是否引用了 skills/ 目录..."

RES_TO_SKILL=$(grep -rn --include="*.json" --include="*.xml" --include="*.properties" -E 'skills/' "$REPO_ROOT"/db-*/src/main/resources/ 2>/dev/null || true)
if [ -n "$RES_TO_SKILL" ]; then
    echo "  ✗ 失败: resources 中引用了 skills/ 目录:"
    echo "$RES_TO_SKILL" | sed 's/^/    /'
    echo "  ↳ 修复: 资源文件不应依赖 skills/ 中的任何内容"
    ERRORS=$((ERRORS + 1))
else
    echo "  ✓ 通过"
fi

# --------------------------------------------------------------------------
# 检查 4: pom.xml 中不得将 skills/ 作为 resource 目录
# --------------------------------------------------------------------------
echo "[检查 4] pom.xml 中是否将 skills/ 纳入构建..."

POM_SKILL=$(grep -rn --include="pom.xml" -E 'skills' "$REPO_ROOT" 2>/dev/null || true)
if [ -n "$POM_SKILL" ]; then
    echo "  ✗ 失败: pom.xml 中引用了 skills/:"
    echo "$POM_SKILL" | sed 's/^/    /'
    echo "  ↳ 修复: skills/ 不应参与 Maven 构建过程"
    ERRORS=$((ERRORS + 1))
else
    echo "  ✓ 通过"
fi

# --------------------------------------------------------------------------
# 检查 5: skills/*.md 中不得引用 Java 类名（全限定名模式）
# --------------------------------------------------------------------------
echo "[检查 5] skills/ 中是否引用了 Java 全限定类名..."

SKILL_JAVA_CLASS=$(grep -rn --include="*.md" -E 'com\.createdb\.' "$REPO_ROOT/skills/" 2>/dev/null || true)
if [ -n "$SKILL_JAVA_CLASS" ]; then
    echo "  ✗ 失败: skills/ 中引用了 Java 类名:"
    echo "$SKILL_JAVA_CLASS" | sed 's/^/    /'
    echo "  ↳ 修复: skills 不应引用代码模块的 Java 类，使用 db-connection.json 作为接口"
    ERRORS=$((ERRORS + 1))
else
    echo "  ✓ 通过"
fi

# --------------------------------------------------------------------------
# 结果汇总
# --------------------------------------------------------------------------
echo ""
echo "=== 检查完成 ==="
if [ $ERRORS -eq 0 ]; then
    echo "✓ 所有边界检查通过 — skills/ 与代码模块完全隔离"
    exit 0
else
    echo "✗ 发现 $ERRORS 个边界违规"
    echo "  参考: AGENTS.md '规则 1：skills/ 与代码模块完全隔离'"
    exit 1
fi
