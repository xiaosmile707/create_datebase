#!/usr/bin/env bash
#
# check-stale — 过期检测：验证 skills/ 声明版本与 sql/ 目录版本的一致性
#
# 用法: bin/check-stale
# 退出码: 0=通过, 1=存在不一致
#
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
ERRORS=0

echo "=== 版本一致性检查 ==="
echo ""

# --------------------------------------------------------------------------
# 版本映射定义（兼容 bash 3.x，不使用 declare -A）
# skills/ 中声明的版本 → db-*/src/main/resources/sql/ 下应存在的目录名
# --------------------------------------------------------------------------

get_versions() {
    case "$1" in
        mysql)      echo "8.0 5.7" ;;
        postgresql) echo "16 15 14" ;;
        oracle)     echo "23ai 21c" ;;
        clickhouse) echo "21.8 22.8" ;;
        h2)         echo "default" ;;
    esac
}

DBS="mysql postgresql oracle clickhouse h2"

# --------------------------------------------------------------------------
# 检查 1: skills/ 声明的版本在 sql/ 目录中是否存在
# --------------------------------------------------------------------------
echo "[检查 1] skills/ 声明版本 → sql/ 目录是否存在..."

CHECK1_ERRORS=0
for db in $DBS; do
    SQL_DIR="$REPO_ROOT/db-$db/src/main/resources/sql"
    if [ ! -d "$SQL_DIR" ]; then
        echo "  ✗ 失败: $SQL_DIR 目录不存在"
        echo "  ↳ 修复: 创建 db-$db/src/main/resources/sql/ 目录及版本子目录"
        CHECK1_ERRORS=$((CHECK1_ERRORS + 1))
        continue
    fi

    for ver in $(get_versions "$db"); do
        if [ ! -d "$SQL_DIR/$ver" ]; then
            echo "  ✗ 失败: db-$db/src/main/resources/sql/$ver/ 目录不存在"
            echo "  ↳ 修复: 创建该版本目录并添加 schema.sql, seed.sql, test.sql, cleanup.sql"
            echo "  ↳ 参考: skills/$db/SKILL.md 声明支持此版本"
            CHECK1_ERRORS=$((CHECK1_ERRORS + 1))
        fi
    done
done
ERRORS=$((ERRORS + CHECK1_ERRORS))
if [ $CHECK1_ERRORS -eq 0 ]; then echo "  ✓ 通过"; fi

# --------------------------------------------------------------------------
# 检查 2: sql/ 目录中存在的版本是否在 skills/ 中有声明
# --------------------------------------------------------------------------
echo "[检查 2] sql/ 目录版本 → skills/ 是否声明..."

CHECK2_ERRORS=0
for db in $DBS; do
    SQL_DIR="$REPO_ROOT/db-$db/src/main/resources/sql"
    [ ! -d "$SQL_DIR" ] && continue

    for dir in "$SQL_DIR"/*/; do
        [ ! -d "$dir" ] && continue
        ver=$(basename "$dir")
        DECLARED_VERSIONS=$(get_versions "$db")
        FOUND=0
        for dv in $DECLARED_VERSIONS; do
            if [ "$ver" = "$dv" ]; then
                FOUND=1
                break
            fi
        done
        if [ $FOUND -eq 0 ]; then
            echo "  ✗ 失败: db-$db/src/main/resources/sql/$ver/ 存在但 skills/$db/SKILL.md 未声明"
            echo "  ↳ 修复: 在 skills/$db/SKILL.md 版本列表中添加 $ver，或删除该孤立目录"
            CHECK2_ERRORS=$((CHECK2_ERRORS + 1))
        fi
    done
done
ERRORS=$((ERRORS + CHECK2_ERRORS))
if [ $CHECK2_ERRORS -eq 0 ]; then echo "  ✓ 通过"; fi

# --------------------------------------------------------------------------
# 检查 3: 每个版本目录是否包含必需的四个 SQL 文件
# --------------------------------------------------------------------------
echo "[检查 3] sql/ 版本目录是否包含完整的 SQL 文件集..."

CHECK3_ERRORS=0
REQUIRED_FILES="schema.sql seed.sql test.sql cleanup.sql"
for db in $DBS; do
    SQL_DIR="$REPO_ROOT/db-$db/src/main/resources/sql"
    [ ! -d "$SQL_DIR" ] && continue

    for ver in $(get_versions "$db"); do
        VER_DIR="$SQL_DIR/$ver"
        [ ! -d "$VER_DIR" ] && continue

        for f in $REQUIRED_FILES; do
            if [ ! -f "$VER_DIR/$f" ]; then
                echo "  ✗ 失败: db-$db/src/main/resources/sql/$ver/$f 缺失"
                echo "  ↳ 修复: 创建该文件（参考同数据库其他版本的同名文件）"
                CHECK3_ERRORS=$((CHECK3_ERRORS + 1))
            fi
        done
    done
done
ERRORS=$((ERRORS + CHECK3_ERRORS))
if [ $CHECK3_ERRORS -eq 0 ]; then echo "  ✓ 通过"; fi

# --------------------------------------------------------------------------
# 检查 4: skills/ 中引用的 Docker 镜像格式是否合法
# --------------------------------------------------------------------------
echo "[检查 4] skills/ 引用的 Docker 镜像格式..."

CHECK4_ERRORS=0
# 验证每个数据库 skill 文件存在
for db in $DBS; do
    SKILL_FILE="$REPO_ROOT/skills/$db/SKILL.md"
    if [ ! -f "$SKILL_FILE" ]; then
        echo "  ✗ 失败: skills/$db/SKILL.md 不存在"
        echo "  ↳ 修复: 创建该 Skill 定义文件"
        CHECK4_ERRORS=$((CHECK4_ERRORS + 1))
    fi
done
ERRORS=$((ERRORS + CHECK4_ERRORS))
if [ $CHECK4_ERRORS -eq 0 ]; then echo "  ✓ 通过"; fi

# --------------------------------------------------------------------------
# 结果汇总
# --------------------------------------------------------------------------
echo ""
echo "=== 检查完成 ==="
if [ $ERRORS -eq 0 ]; then
    echo "✓ 所有版本一致性检查通过 — skills/ 声明与 sql/ 目录同步"
    exit 0
else
    echo "✗ 发现 $ERRORS 个不一致项"
    echo "  参考: AGENTS.md '版本一致性约束'"
    exit 1
fi
